<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#180006">
<title>الرياض</title>
<link rel="manifest" href="manifest.json">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="الرياض">
<script>
if('serviceWorker' in navigator){
  window.addEventListener('load',()=>{ navigator.serviceWorker.register('./sw.js').catch(()=>{}); });
}
let _deferredPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault(); _deferredPrompt=e;
  const btn=document.getElementById('pwa-install-btn');
  if(btn) btn.style.display='flex';
});
window.addEventListener('appinstalled',()=>{
  const btn=document.getElementById('pwa-install-btn');
  if(btn) btn.style.display='none';
  _deferredPrompt=null;
});
function installPWA(){
  if(!_deferredPrompt) return;
  _deferredPrompt.prompt();
  _deferredPrompt.userChoice.then(()=>{ _deferredPrompt=null; });
}
</script>
<style>
:root{
  --font:-apple-system,"Segoe UI","Tahoma",sans-serif;
  --mono:"Courier New",monospace;
  --s1:rgba(24,0,8,0.88);--s2:rgba(40,0,18,0.92);
  --border:rgba(255,85,128,0.25);--border2:rgba(255,85,128,0.13);
  --fire:#ff5580;--fire2:#ff8fab;--gold:#ffb3c6;
  --ash:#f5d0da;--ash2:#c9899a;--ash3:#8a4f5e;
  --green:#4aad7e;--red:#ff2255;
  --r:5px;--press:0.08s;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;direction:rtl;font-family:var(--font)}
body{
  background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 55%, rgba(0,0,0,0.55) 100%),
    radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px),
    url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.000'/%3E%3C/svg%3E"),
    linear-gradient(57deg, #180006 0%, #8B0033 50%, #FF5580 100%);
  background-size: 20px 20px, cover;
  background-attachment:fixed;
  color:var(--ash);overflow:hidden;
}

.screen{position:fixed;inset:0;z-index:1;display:none;flex-direction:column;background:transparent}
.screen.active{display:flex}

/* ══ SPLASH ══ */
#splash{align-items:center;justify-content:center;padding:24px 20px;gap:32px}
.splash-brand{text-align:center}
.splash-name{font-size:clamp(2.6rem,11vw,3.8rem);font-weight:900;color:var(--fire2);letter-spacing:0.04em;line-height:1.1}
.splash-under{font-size:clamp(0.78rem,3vw,0.9rem);color:var(--ash);margin-top:7px;letter-spacing:0.05em;opacity:0.85}
.splash-cards{display:flex;flex-direction:column;width:100%;max-width:400px;gap:12px}
.splash-card{
  padding:clamp(24px,7vw,38px) 20px;
  display:flex;align-items:center;gap:16px;
  cursor:pointer;border:1px solid var(--border);border-radius:8px;
  background:rgba(24,0,8,0.75);color:var(--ash);font-family:var(--font);text-align:right;
  transition:background var(--press),border-color var(--press),transform var(--press);
  -webkit-user-select:none;user-select:none;
}
.splash-card:active{background:var(--s2);border-color:var(--fire);transform:scale(0.98)}
.sc-icon{font-size:clamp(2rem,8vw,2.6rem);flex-shrink:0}
.sc-text{display:flex;flex-direction:column;gap:5px}
.sc-title{font-size:clamp(1.05rem,4.5vw,1.25rem);font-weight:800;color:var(--ash)}
.sc-desc{font-size:clamp(0.7rem,2.5vw,0.78rem);color:var(--ash3);line-height:1.5}

/* ══ INSTALL ══ */
.install-bar{
  width:100%;max-width:400px;
  display:none;flex-direction:column;gap:6px;
}
.install-bar.show{display:flex}
.install-btn-store{
  width:100%;padding:13px 18px;
  background:rgba(74,173,126,0.1);border:1px solid rgba(74,173,126,0.3);
  border-radius:8px;cursor:pointer;font-family:var(--font);color:var(--green);
  display:flex;align-items:center;justify-content:center;gap:10px;
  font-size:0.85rem;font-weight:700;
  transition:background var(--press),transform var(--press);
  -webkit-user-select:none;user-select:none;
}
.install-btn-store:active{background:rgba(74,173,126,0.2);transform:scale(0.98)}
.ios-hint-store{
  padding:9px 13px;
  background:rgba(74,173,126,0.07);border:1px solid rgba(74,173,126,0.2);
  border-radius:var(--r);font-size:0.7rem;color:var(--ash3);
  font-family:var(--mono);line-height:1.7;text-align:center;display:none;
}
.ios-hint-store.show{display:block}

/* ══ APP ══ */
#app{overflow:hidden}
.topbar{
  height:50px;background:rgba(18,0,8,0.82);
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0;
}
.back-btn{background:none;border:none;color:var(--ash2);cursor:pointer;font-size:22px;padding:4px 6px;line-height:1;transition:color var(--press),transform var(--press);-webkit-user-select:none;user-select:none}
.back-btn:active{color:var(--fire2);transform:scale(0.88)}
.topbar-title{font-size:0.9rem;font-weight:700;color:var(--ash)}
.sel-badge{margin-right:auto;background:rgba(255,85,128,0.15);border:1px solid rgba(255,85,128,0.35);border-radius:12px;padding:3px 10px;font-size:0.65rem;color:var(--fire2);font-family:var(--mono);display:none}
.topbar-install-btn{
  background:rgba(74,173,126,0.12);border:1px solid rgba(74,173,126,0.3);
  border-radius:var(--r);padding:5px 10px;color:var(--green);
  font-size:0.7rem;font-weight:700;font-family:var(--font);
  cursor:pointer;display:none;align-items:center;gap:5px;
  transition:background var(--press),transform var(--press);
  -webkit-user-select:none;user-select:none;white-space:nowrap;
}
.topbar-install-btn.show{display:flex}
.topbar-install-btn:active{background:rgba(74,173,126,0.22);transform:scale(0.95)}

/* ══ CONTROLS ══ */
.controls{
  padding:9px 14px;background:rgba(18,0,8,0.72);
  backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
  border-bottom:1px solid var(--border2);
  flex-shrink:0;display:flex;gap:8px;align-items:center;
}
.srch-wrap{flex:1;position:relative}
.srch-wrap input{
  width:100%;background:rgba(30,0,12,0.7);border:1px solid var(--border);
  border-radius:var(--r);padding:9px 12px;
  color:var(--ash);font-family:var(--font);font-size:0.83rem;
  outline:none;direction:rtl;transition:border-color 0.12s;
}
.srch-wrap input:focus{border-color:var(--fire)}
.srch-wrap input::placeholder{color:var(--ash3)}
.sort-sel{
  background:rgba(30,0,12,0.7);border:1px solid var(--border2);
  border-radius:var(--r);padding:9px 10px;
  color:var(--ash2);font-family:var(--font);font-size:0.75rem;outline:none;cursor:pointer;direction:rtl;flex-shrink:0;
}
.sort-sel option{background:#1a0008}

/* ══ CAT FILTER BAR ══ */
.cat-bar{
  padding:8px 14px;background:rgba(18,0,8,0.65);
  backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);
  border-bottom:1px solid var(--border2);
  flex-shrink:0;display:flex;gap:6px;overflow-x:auto;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;
}
.cat-bar::-webkit-scrollbar{display:none}
.cat-bar.hidden{display:none}
.cpill{
  background:rgba(30,0,12,0.6);border:1px solid var(--border2);
  border-radius:20px;padding:5px 13px;font-size:0.72rem;font-weight:700;color:var(--ash3);
  cursor:pointer;white-space:nowrap;flex-shrink:0;
  transition:color 0.1s,border-color 0.1s,background 0.1s;
  font-family:var(--font);-webkit-user-select:none;user-select:none;
}
.cpill.active{background:rgba(255,85,128,0.13);border-color:var(--fire);color:var(--fire2)}

/* ══ PRODUCTS LIST ══ */
.products-list{flex:1;overflow-y:auto;padding:10px 14px;-webkit-overflow-scrolling:touch;overscroll-behavior:contain}

.prow{
  background:rgba(20,0,8,0.72);border:1px solid var(--border2);
  border-radius:var(--r);margin-bottom:7px;
  cursor:pointer;-webkit-user-select:none;user-select:none;
  transition:background var(--press),border-color var(--press),transform var(--press);
  overflow:hidden;
}
.prow:active{background:var(--s2);transform:scale(0.985)}
.prow.selected{border-color:var(--fire);background:rgba(255,85,128,0.1)}
.prow.selected:active{background:rgba(255,85,128,0.18)}

/* صف المعلومات الأساسية */
.prow-main{display:flex;align-items:center;justify-content:space-between;padding:13px 14px;}
.prow-left{display:flex;flex-direction:column;gap:3px;flex:1;min-width:0}
.prow-name{font-size:0.85rem;font-weight:700;color:var(--ash);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.prow-cat{font-size:0.62rem;color:var(--ash3);font-family:var(--mono)}
.prow-right{display:flex;align-items:center;gap:10px;flex-shrink:0}

.price-badge{font-size:0.62rem;font-weight:900;padding:2px 7px;border-radius:10px;font-family:var(--mono);white-space:nowrap;}
.price-badge.wholesale{background:rgba(196,122,255,0.15);color:#c47aff;border:1px solid rgba(196,122,255,0.3)}
.price-badge.retail{background:rgba(74,173,126,0.15);color:var(--green);border:1px solid rgba(74,173,126,0.3)}

.prow-price{font-size:0.9rem;font-weight:900;color:var(--fire2);font-family:var(--mono)}
.prow-price sub{font-size:0.55rem;color:var(--gold)}
.prow-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;color:transparent;transition:border-color var(--press),background var(--press),color var(--press)}
.prow.selected .prow-check{border-color:var(--fire);background:var(--fire);color:#fff}

/* زر التفاصيل */
.prow-desc-btn{
  display:flex;align-items:center;justify-content:space-between;
  padding:6px 14px 8px;border-top:1px solid var(--border2);
  font-size:0.7rem;font-weight:700;color:var(--ash3);
  transition:color var(--press),background var(--press);
}
.prow-desc-btn:active{color:var(--fire2);background:rgba(255,85,128,0.05)}
.prow-desc-btn .dba{font-size:0.6rem;transition:transform 0.15s;display:inline-block}
.prow-desc-btn.open .dba{transform:rotate(180deg)}
.prow-desc-btn.open{color:var(--ash2)}

/* محتوى التفاصيل */
.prow-desc-body{
  display:none;padding:0 14px 12px;
  font-size:0.78rem;color:var(--ash2);line-height:1.6;
  border-top:1px solid var(--border2);
}
.prow-desc-body.open{display:block}
.prow-desc-img-wrap{
  width:100%;aspect-ratio:1/1;
  border-radius:var(--r);border:1px solid var(--border2);
  margin-bottom:8px;margin-top:8px;overflow:hidden;
  background:rgba(30,0,12,0.5);
}
.prow-desc-img{
  width:100%;height:100%;object-fit:contain;display:block;
}

.empty-list{text-align:center;padding:40px 20px;color:var(--ash3);font-size:0.8rem}

/* ══ SUMMARY + SEND ══ */
.summary-bar{
  background:rgba(18,0,8,0.78);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
  border-top:1px solid var(--border);padding:8px 14px;flex-shrink:0;
  display:none;flex-direction:row;align-items:center;justify-content:space-between;
}
.summary-bar.visible{display:flex}
.summary-label{font-size:0.68rem;color:var(--ash3)}
.summary-amount{font-size:1.05rem;font-weight:900;color:var(--fire2);font-family:var(--mono)}
.summary-amount sub{font-size:0.55rem;color:var(--gold)}

.send-wrap{padding:10px 14px 14px;background:rgba(18,0,8,0.78);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);flex-shrink:0}
.send-btn{
  width:100%;padding:14px;background:var(--fire);border:none;border-radius:var(--r);
  color:#fff;font-family:var(--font);font-size:0.95rem;font-weight:700;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:10px;
  transition:opacity var(--press),transform var(--press);-webkit-user-select:none;user-select:none;
}
.send-btn:active{opacity:0.82;transform:scale(0.97)}

/* ══ MODALS ══ */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:300;align-items:flex-end;justify-content:center}
.modal-ov.open{display:flex}
.modal-box{
  background:rgba(24,0,10,0.97);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
  border:1px solid var(--border);border-bottom:none;border-radius:8px 8px 0 0;
  width:100%;max-width:480px;padding:22px 18px 28px;position:relative;
}
.modal-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--fire),var(--fire2),transparent)}
.modal-title{font-size:0.95rem;font-weight:700;color:var(--ash);margin-bottom:5px;text-align:center}
.modal-sub{font-size:0.72rem;color:var(--ash3);text-align:center;margin-bottom:18px;line-height:1.5}

.pricing-choices{display:flex;gap:10px;margin-bottom:0}
.pricing-btn{
  flex:1;padding:18px 12px;
  background:rgba(40,0,18,0.7);border:1px solid var(--border);border-radius:var(--r);
  cursor:pointer;font-family:var(--font);color:var(--ash);
  display:flex;flex-direction:column;align-items:center;gap:7px;
  transition:background var(--press),border-color var(--press),transform var(--press);
  -webkit-user-select:none;user-select:none;
}
.pricing-btn:active{transform:scale(0.96)}
.pricing-btn.wholesale-btn:active{border-color:#c47aff;background:rgba(196,122,255,0.12)}
.pricing-btn.retail-btn:active{border-color:var(--green);background:rgba(74,173,126,0.12)}
.pb-icon{font-size:1.8rem}
.pb-title{font-size:0.9rem;font-weight:800}
.pb-price{font-size:1rem;font-weight:900;font-family:var(--mono)}
.pb-desc{font-size:0.64rem;color:var(--ash3);text-align:center}

.type-choices{display:flex;gap:10px}
.type-btn{
  flex:1;padding:16px 10px;background:rgba(40,0,18,0.7);border:1px solid var(--border);border-radius:var(--r);
  cursor:pointer;font-family:var(--font);color:var(--ash);
  display:flex;flex-direction:column;align-items:center;gap:6px;
  transition:background var(--press),border-color var(--press),transform var(--press);
  -webkit-user-select:none;user-select:none;
}
.type-btn:active{border-color:var(--fire);background:rgba(255,85,128,0.12);transform:scale(0.96)}
.type-btn .tb-icon{font-size:1.6rem}
.type-btn .tb-title{font-size:0.85rem;font-weight:700}
.type-btn .tb-desc{font-size:0.65rem;color:var(--ash3);text-align:center;line-height:1.4}

.mfield{display:flex;flex-direction:column;gap:4px;margin-bottom:11px}
.mfield label{font-size:0.63rem;font-weight:700;color:var(--ash3);text-transform:uppercase;letter-spacing:0.07em;font-family:var(--mono)}
.mfield input,.mfield textarea{
  background:rgba(30,0,12,0.7);border:1px solid var(--border);border-radius:var(--r);
  padding:9px 11px;color:var(--ash);font-family:var(--font);font-size:0.83rem;
  outline:none;direction:rtl;width:100%;transition:border-color 0.12s;
}
.mfield input:focus,.mfield textarea:focus{border-color:var(--fire)}
.mfield input::placeholder,.mfield textarea::placeholder{color:var(--ash3)}

.modal-scroll{max-height:62vh;overflow-y:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch}
.modal-items{
  background:rgba(30,0,12,0.6);border:1px solid var(--border2);
  border-radius:var(--r);padding:10px 12px;margin-bottom:14px;max-height:120px;overflow-y:auto;
}
.mi-row{display:flex;justify-content:space-between;font-size:0.74rem;padding:3px 0;border-bottom:1px solid var(--border2)}
.mi-row:last-child{border-bottom:none;font-weight:700;color:var(--fire2);padding-top:7px;margin-top:3px}
.mi-row .mn{color:var(--ash)}
.mi-row .mp{font-family:var(--mono)}

.loc-btn{
  width:100%;padding:10px;background:rgba(74,173,126,0.08);border:1px solid rgba(74,173,126,0.25);
  border-radius:var(--r);color:var(--green);font-family:var(--font);font-size:0.8rem;font-weight:700;
  cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;
  transition:background var(--press),transform var(--press);-webkit-user-select:none;user-select:none;
}
.loc-btn:active{background:rgba(74,173,126,0.15);transform:scale(0.97)}
.loc-status{font-size:0.65rem;color:var(--ash3);margin-top:4px;font-family:var(--mono);text-align:center}
.or-divider{text-align:center;font-size:0.7rem;color:var(--ash3);margin:10px 0;font-family:var(--mono)}

.modal-actions{display:flex;gap:8px;margin-top:16px}
.btn-cancel{
  flex:1;padding:11px;background:rgba(40,0,18,0.8);border:1px solid var(--border);
  color:var(--ash2);border-radius:var(--r);font-family:var(--font);font-size:0.83rem;font-weight:600;cursor:pointer;
  transition:background var(--press),transform var(--press);-webkit-user-select:none;user-select:none;
}
.btn-cancel:active{background:rgba(60,0,28,0.9);transform:scale(0.97)}
.btn-go{
  flex:2;padding:11px;background:var(--fire);border:none;color:#fff;border-radius:var(--r);
  font-family:var(--font);font-size:0.88rem;font-weight:700;cursor:pointer;
  transition:opacity var(--press),transform var(--press);-webkit-user-select:none;user-select:none;
}
.btn-go:active{opacity:0.82;transform:scale(0.97)}
.btn-go.green{background:var(--green)}

.confirm-body{text-align:center;padding:4px 0 14px}
.confirm-emoji{font-size:2.2rem;display:block;margin-bottom:8px}
.confirm-title{font-size:0.95rem;font-weight:700;color:var(--ash);margin-bottom:10px}
.confirm-msg{font-size:0.78rem;color:var(--ash3);line-height:1.7;white-space:pre-line}

.qty-wrap{
  display:flex;align-items:center;gap:0;
  background:rgba(30,0,12,0.7);border:1px solid var(--border);
  border-radius:var(--r);overflow:hidden;margin-top:14px;
}
.qty-btn{
  width:42px;height:42px;border:none;background:rgba(255,85,128,0.1);
  color:var(--fire2);font-size:1.2rem;font-weight:900;cursor:pointer;
  font-family:var(--mono);flex-shrink:0;
  transition:background var(--press);-webkit-user-select:none;user-select:none;
}
.qty-btn:active{background:rgba(255,85,128,0.22)}
.qty-input{
  flex:1;border:none;background:transparent;
  color:var(--ash);font-family:var(--mono);font-size:1rem;font-weight:700;
  text-align:center;outline:none;padding:0;
}
.qty-label{font-size:0.72rem;color:var(--ash3);text-align:center;margin-top:6px;font-family:var(--mono)}
.qty-total{font-size:0.9rem;font-weight:900;color:var(--fire2);font-family:var(--mono);text-align:center;margin-top:5px;}

#toast{
  position:fixed;bottom:18px;left:50%;
  transform:translateX(-50%) translateY(55px);
  background:rgba(24,0,10,0.95);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  border:1px solid var(--border);border-radius:var(--r);
  padding:8px 16px;font-size:0.76rem;font-weight:700;
  transition:transform 0.15s ease;z-index:9999;white-space:nowrap;font-family:var(--mono);
}
#toast.show{transform:translateX(-50%) translateY(0)}
#toast.ts{border-color:var(--green);color:var(--green)}
#toast.te{border-color:var(--red);color:var(--red)}
#toast.ti{border-color:var(--fire);color:var(--fire2)}

::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,85,128,0.2);border-radius:2px}
</style>
</head>
<body>

<!-- ══ SPLASH ══ -->
<div id="splash" class="screen active">
  <div class="splash-brand">
    <div class="splash-name">الرياض</div>
    <div class="splash-under">تحت إدارة الشيخ حسين</div>
  </div>
  <div class="splash-cards">
    <button class="splash-card" onclick="openTab('offers')">
      <span class="sc-icon">🎁</span>
      <div class="sc-text">
        <span class="sc-title">العروض والهدايا</span>
