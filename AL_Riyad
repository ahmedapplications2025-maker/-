<div id="toast"></div>

<script>
const SK='admin_products_v1', IK='admin_inbox_v1';
let products=[], selected={}, gpsCoords=null, currentTab='products', catFilter='all';

let pendingPricingId=null;

const fmtP=v=>Number(v).toLocaleString('ar');
const esc=s=>String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,6);
const loadP=()=>{const r=localStorage.getItem(SK);return r?JSON.parse(r):[]};

/* ── HISTORY ── */
history.replaceState({page:'splash'},'');
window.addEventListener('popstate',e=>{
  const page=e.state?.page||'splash';
  const openM=document.querySelector('.modal-ov.open');
  if(openM){openM.classList.remove('open');history.pushState({page:'app'},'');return;}
  if(page==='splash') showScreen('splash');
  else showScreen('app');
});

function showScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(name==='splash'?'splash':'app').classList.add('active');
}

/* ── TABS ── */
function openTab(tab){
  currentTab=tab; catFilter='all';
  products=loadP();
  selected={};
  showScreen('app');
  history.pushState({page:'app'},'');
  document.getElementById('topbar-title').textContent=tab==='offers'?'العروض والهدايا':'المنتجات';
  document.getElementById('srch').value='';
  document.getElementById('sort-sel').value='name-asc';
  renderList(); updateSummary();
}

function goBack(){history.back();}

/* ── CAT FILTER ── */
function setCatFilter(cat, el){
  catFilter = cat;
  document.querySelectorAll('#cat-bar .cpill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  renderList();
}

function buildCatBar(){
  const type = currentTab==='offers'?'offer':'product';
  const cats = [...new Set(
    products
      .filter(p=>(p.type||'product')===type && p.category)
      .map(p=>p.category)
  )];
  const bar = document.getElementById('cat-bar');
  if(!cats.length){ bar.classList.add('hidden'); return; }
  bar.classList.remove('hidden');
  bar.innerHTML = `<span class="cpill ${catFilter==='all'?'active':''}" onclick="setCatFilter('all',this)">الكل</span>`
    + cats.map(c=>`<span class="cpill ${catFilter===c?'active':''}" onclick="setCatFilter('${esc(c)}',this)">${esc(c)}</span>`).join('');
}

/* ── RENDER ── */
function renderList(){
  const srch=document.getElementById('srch').value.trim().toLowerCase();
  const sort=document.getElementById('sort-sel').value;
  const type=currentTab==='offers'?'offer':'product';

  let list=products.filter(p=>(p.type||'product')===type);
  // فلتر التصنيف
  if(catFilter!=='all') list=list.filter(p=>(p.category||'')===catFilter);
  // فلتر البحث
  if(srch) list=list.filter(p=>p.name.toLowerCase().includes(srch)||(p.keywords||'').toLowerCase().includes(srch)||(p.category||'').toLowerCase().includes(srch));

  list.sort((a,b)=>{
    const pa=a.price_r||a.price||0, pb=b.price_r||b.price||0;
    return sort==='name-asc'?a.name.localeCompare(b.name,'ar'):
           sort==='name-desc'?b.name.localeCompare(a.name,'ar'):
           sort==='price-asc'?pa-pb: pb-pa;
  });

  buildCatBar();

  const el=document.getElementById('plist');
  if(!list.length){el.innerHTML='<div class="empty-list">لا توجد منتجات في هذا القسم</div>';return;}

  el.innerHTML=list.map(p=>{
    const sel=selected[p.id];
    const unitP=sel?parseFloat(sel.unitPrice)||0:(p.price_r||p.price||0);
    const qty=sel?parseInt(sel.qty)||1:1;
    const lineTotal=unitP*qty;
    const priceToShow=sel
      ? fmtP(lineTotal)+'<sub>جـ</sub>'
      : fmtP(p.price_r||p.price||0)+'<sub>جـ</sub>';
    const badgeHtml=sel
      ? `<span class="price-badge ${sel.pricingType==='wholesale'?'wholesale':'retail'}">${sel.pricingType==='wholesale'?'جملة':'قطاعي'}</span>`
        +(qty>1?`<span class="price-badge retail">×${qty}</span>`:'')
      : '';

    // صورة + وصف
    const hasDesc = !!(p.desc || p.image);
    const descSection = hasDesc ? `
      <div class="prow-desc-btn" id="dbt-${p.id}" onclick="toggleDesc(event,'${p.id}')">
        <span>التفاصيل</span>
        <span class="dba">▼</span>
      </div>
      <div class="prow-desc-body" id="dbb-${p.id}">
        ${p.image?`<div class="prow-desc-img-wrap"><img class="prow-desc-img" src="${esc(p.image)}" alt="${esc(p.name)}" onerror="this.parentElement.style.display='none'" /></div>`:''}
        ${p.desc?`<span>${esc(p.desc)}</span>`:''}
      </div>` : '';

    return `<div class="prow${sel?' selected':''}" id="pr-${p.id}">
      <div class="prow-main" onclick="tapProduct('${p.id}')">
        ${p.image&&!p.desc?`<img src="${esc(p.image)}" style="width:44px;height:44px;object-fit:cover;border-radius:var(--r);border:1px solid var(--border2);flex-shrink:0;margin-left:10px" loading="lazy" onerror="this.style.display='none'" />`:''}
        <div class="prow-left">
          <div class="prow-name">${esc(p.name)}</div>
          <div class="prow-cat">${p.category?esc(p.category):''}</div>
        </div>
        <div class="prow-right">
          ${badgeHtml}
          <div class="prow-price">${priceToShow}</div>
          <div class="prow-check">${sel?'✓':''}</div>
        </div>
      </div>
      ${descSection}
    </div>`;
  }).join('');
}

/* ── TOGGLE DESC ── */
function toggleDesc(e, id){
  e.stopPropagation();
  const btn = document.getElementById('dbt-'+id);
  const body = document.getElementById('dbb-'+id);
  const isOpen = body.classList.contains('open');
  btn.classList.toggle('open', !isOpen);
  body.classList.toggle('open', !isOpen);
}

/* ── TAP PRODUCT ── */
function tapProduct(id){
  const p=products.find(x=>x.id===id);
  if(!p) return;
  if(selected[id]){
    const s=selected[id];
    openQtyModal(id, s.pricingType, s.unitPrice, s.qty, p.name);
    return;
  }
  pendingPricingId=id;
  document.getElementById('pricing-product-name').textContent=p.name;
  document.getElementById('price-wholesale').textContent=fmtP(p.price_w||p.price||0)+' جـ';
  document.getElementById('price-retail').textContent=fmtP(p.price_r||p.price||0)+' جـ';
  openModal('pricing-modal');
}

function selectPricing(type){
  const id=pendingPricingId; if(!id) return;
  const p=products.find(x=>x.id===id); if(!p) return;
  const unitPrice=type==='wholesale'
    ? parseFloat(p.price_w||p.price||0)
    : parseFloat(p.price_r||p.price||0);
  closeModal('pricing-modal');
  openQtyModal(id, type, unitPrice, 1, p.name);
}

function openQtyModal(id, pricingType, unitPrice, initQty, name){
  unitPrice=parseFloat(unitPrice)||0;
  initQty=parseInt(initQty)||1;
  document.getElementById('qty-product-name').textContent=name;
  document.getElementById('qty-type-label').textContent=pricingType==='wholesale'?'جملة':'قطاعي';
  document.getElementById('qty-unit-price').textContent=fmtP(unitPrice)+' جـ';
  const inp=document.getElementById('qty-input');
  inp.value=initQty;
  refreshQtyTotal(unitPrice, initQty);
  document.getElementById('qty-plus-btn').onclick=()=>{inp.value=Math.max(1,(parseInt(inp.value)||1)+1);refreshQtyTotal(unitPrice,parseInt(inp.value));};
  document.getElementById('qty-minus-btn').onclick=()=>{inp.value=Math.max(1,(parseInt(inp.value)||1)-1);refreshQtyTotal(unitPrice,parseInt(inp.value));};
  inp.oninput=()=>{const v=Math.max(1,parseInt(inp.value)||1);inp.value=v;refreshQtyTotal(unitPrice,v);};
  document.getElementById('qty-confirm-btn').onclick=()=>{
    const qty=Math.max(1,parseInt(inp.value)||1);
    selected[id]={pricingType,unitPrice,qty,price:unitPrice*qty};
    closeModal('qty-modal');
    pendingPricingId=null;
    renderList(); updateSummary();
  };
  openModal('qty-modal');
}

function refreshQtyTotal(unitPrice, qty){
  document.getElementById('qty-total').textContent='الإجمالي: '+fmtP((parseFloat(unitPrice)||0)*(parseInt(qty)||1))+' جـ';
}

function updateSummary(){
  const ids=Object.keys(selected);
  document.getElementById('summary-bar').classList.toggle('visible',ids.length>0);
  const badge=document.getElementById('sel-badge');
  badge.style.display=ids.length?'':'none';
  badge.textContent=ids.length+' محدد';
  let total=0;
  ids.forEach(id=>{const s=selected[id];if(s) total+=(parseFloat(s.unitPrice)||0)*(parseInt(s.qty)||1);});
  document.getElementById('sum-val').textContent=fmtP(total);
  document.getElementById('sum-count').textContent=ids.length?ids.length+' منتج':'';
}

/* ── SEND ── */
function onSend(){
  if(!Object.keys(selected).length) return toast('اختر منتجاً واحداً على الأقل','te');
  openModal('type-modal');
}

function openBookForm(){
  closeModal('type-modal');
  buildSummary('book-items-summary');
  const d=new Date(Date.now()+3600000);
  const pad=n=>String(n).padStart(2,'0');
  document.getElementById('book-time').value=`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  document.getElementById('book-phone').value='';
  document.getElementById('book-notes').value='';
  openModal('book-modal');
}

function submitBook(){
  const time=document.getElementById('book-time').value;
  if(!time) return toast('حدد موعد الاستلام','te');
  const {items,total,pricingType}=buildOrderData();
  const phone=document.getElementById('book-phone').value.trim();
  const notes=document.getElementById('book-notes').value.trim();
  const timeLabel=new Date(time).toLocaleString('ar-EG',{weekday:'short',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
  saveInbox({id:uid(),type:'book',items,total,pricingType,time,phone,notes,createdAt:Date.now(),status:'new'});
  closeModal('book-modal');
  showConfirm('✅','تم إرسال الحجز!',`موعد الاستلام: ${timeLabel}\nالإجمالي: ${fmtP(total)} جنيه`);
}

function openDelivForm(){
  closeModal('type-modal');
  buildSummary('deliv-items-summary');
  ['d-name','d-phone','d-notes','d-location'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('loc-status').textContent='لم يتم تحديد الموقع بعد';
  gpsCoords=null;
  openModal('deliv-modal');
}

function getLocation(){
  const s=document.getElementById('loc-status');
  if(!navigator.geolocation){s.textContent='الموقع غير مدعوم في هذا المتصفح';return;}
  s.textContent='جاري التحديد...';
  navigator.geolocation.getCurrentPosition(
    pos=>{gpsCoords={lat:pos.coords.latitude,lng:pos.coords.longitude};s.innerHTML=`✓ تم — <a href="https://maps.google.com/?q=${gpsCoords.lat},${gpsCoords.lng}" target="_blank" style="color:var(--green)">عرض على الخريطة</a>`;},
    ()=>{s.textContent='تعذر التحديد — تأكد من الإذن';gpsCoords=null;},
    {timeout:10000}
  );
}

function submitDeliv(){
  const name=document.getElementById('d-name').value.trim();
  const phone=document.getElementById('d-phone').value.trim();
  const locManual=document.getElementById('d-location').value.trim();
  if(!name) return toast('أدخل اسمك','te');
  if(!phone) return toast('أدخل رقم تليفونك','te');
  if(!gpsCoords&&!locManual) return toast('حدد موقعك أو اكتبه يدوياً','te');
  const {items,total,pricingType}=buildOrderData();
  const notes=document.getElementById('d-notes').value.trim();
  saveInbox({id:uid(),type:'order',items,total,pricingType,customer:{name,phone,notes,gps:gpsCoords,locationManual:locManual},createdAt:Date.now(),status:'new'});
  closeModal('deliv-modal');
  showConfirm('🛵','تم إرسال طلبك!',`سيتم التواصل معك قريباً\nالإجمالي: ${fmtP(total)} جنيه`);
}

function buildOrderData(){
  const ids=Object.keys(selected);
  const items=ids.map(id=>{
    const p=products.find(x=>x.id===id);
    const s=selected[id];
    if(!p||!s) return null;
    const unitPrice=parseFloat(s.unitPrice)||0;
    const qty=parseInt(s.qty)||1;
    return {id:p.id,name:p.name,unitPrice,qty,lineTotal:unitPrice*qty,pricingType:s.pricingType,category:p.category||''};
  }).filter(Boolean);
  const total=items.reduce((s,it)=>s+it.lineTotal,0);
  const types=[...new Set(items.map(it=>it.pricingType))];
  const pricingType=types.length===1?types[0]:'mixed';
  return {items,total,pricingType};
}

function buildSummary(elId){
  const {items,total}=buildOrderData();
  document.getElementById(elId).innerHTML=
    items.map(it=>`<div class="mi-row"><span class="mn">${esc(it.name)}<span style="font-size:0.6rem;color:var(--ash3)">(${it.pricingType==='wholesale'?'جملة':'قطاعي'}${it.qty>1?' × '+it.qty:''})</span></span><span class="mp">${fmtP(it.lineTotal)} جـ</span></div>`).join('')+
    `<div class="mi-row"><span class="mn" style="font-weight:700">الإجمالي</span><span class="mp">${fmtP(total)} جـ</span></div>`;
}

function showConfirm(emoji,title,msg){
  document.getElementById('confirm-emoji').textContent=emoji;
  document.getElementById('confirm-title').textContent=title;
  document.getElementById('confirm-msg').textContent=msg;
  openModal('confirm-modal');
}

function closeConfirm(){
  closeModal('confirm-modal');
  selected={};renderList();updateSummary();gpsCoords=null;
}

function saveInbox(entry){
  const raw=localStorage.getItem(IK);
  const inbox=raw?JSON.parse(raw):[];
  inbox.unshift(entry);
  localStorage.setItem(IK,JSON.stringify(inbox));
  localStorage.setItem(IK+'_ts',Date.now());
}

function openModal(id){document.getElementById(id).classList.add('open');history.pushState({page:'app',modal:id},'');}
function closeModal(id){document.getElementById(id).classList.remove('open');}

let tt;
function toast(msg,type='ti'){
  const t=document.getElementById('toast');t.textContent=msg;t.className=`show ${type}`;
  clearTimeout(tt);tt=setTimeout(()=>t.className='',2200);
}

window.addEventListener('load',()=>{
  if('serviceWorker' in navigator){
    const sw=`const C='rv4';self.addEventListener('install',e=>e.waitUntil(caches.open(C).then(c=>c.addAll(['.']))));self.addEventListener('fetch',e=>e.respondWith(fetch(e.request).catch(()=>caches.match(e.request))));`;
    navigator.serviceWorker.register(URL.createObjectURL(new Blob([sw],{type:'text/javascript'}))).catch(()=>{});
  }
});

/* ══ INSTALL PWA ══ */
let deferredPrompt=null;

function setInstallVisible(v){
  const bar=document.getElementById('install-bar');
  if(bar) bar.classList.toggle('show',v);
  const tb=document.getElementById('topbar-install-btn');
  if(tb) tb.classList.toggle('show',v);
}

function isInstalled(){
  return window.navigator.standalone===true ||
    window.matchMedia('(display-mode: standalone)').matches ||
    window.matchMedia('(display-mode: fullscreen)').matches;
}

window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();
  deferredPrompt=e;
  setInstallVisible(true);
});

window.addEventListener('appinstalled',()=>{
  deferredPrompt=null;
  setInstallVisible(false);
  toast('✓ تم تثبيت التطبيق','ts');
});

function triggerInstall(){
  if(deferredPrompt){
    deferredPrompt.prompt();
    deferredPrompt.userChoice.then(()=>{ deferredPrompt=null; });
  } else {
    // iOS أو متصفح ما عندوش prompt — وضّح للمستخدم
    const isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)&&!window.MSStream;
    const h=document.getElementById('ios-hint-store');
    if(isIOS&&h){
      h.classList.add('show');
      const bar=document.getElementById('install-bar');
      if(bar) bar.classList.add('show');
    } else {
      toast('افتح الموقع من Chrome واضغط ⋮ ثم تثبيت','ti');
    }
  }
}

// يظهر الزر إذا التطبيق مش مثبت
(function(){
  if(isInstalled()){ setInstallVisible(false); return; }
  // iOS
  const isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)&&!window.MSStream;
  if(isIOS){
    setInstallVisible(true);
    const h=document.getElementById('ios-hint-store');
    if(h) h.classList.add('show');
    return;
  }
  // باقي المتصفحات — اظهر الزر دايماً لو مش مثبت
  setInstallVisible(true);
})();
</script>

